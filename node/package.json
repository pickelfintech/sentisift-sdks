{
  "name": "@sentisift/client",
  "version": "0.1.2",
  "description": "Official TypeScript/JavaScript client for the SentiSift comment-moderation and intelligence API.",
  "license": "SEE LICENSE IN https://sentisift.com/terms.html",
  "author": "Pickel Fintech <tom@sentisift.com>",
  "homepage": "https://sentisift.com",
  "repository": {
    "type": "git",
    "url": "git+https://gitlab.com/pickel-fintech/sentisift-sdks.git",
    "directory": "node"
  },
  "bugs": {
    "url": "https://gitlab.com/pickel-fintech/sentisift-sdks/-/issues",
    "email": "tom@sentisift.com"
  },
  "keywords": [
    "sentisift",
    "sentiment-analysis",
    "comment-moderation",
    "content-moderation",
    "bot-detection",
    "nlp",
    "typescript"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src tests"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.4.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
